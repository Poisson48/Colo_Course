<?xml version="1.0"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.colocourse.app"
    android:installLocation="auto"
    android:versionCode="1"
    android:versionName="0.1.0">

    <!-- Relais Nostr en wss:// : réseau obligatoire. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Savoir si on est hors ligne (bandeau + file d'attente outbox, SPEC §3.5). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Notification locale après un merge distant (SPEC §8). Runtime sur Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true"/>

    <application
        android:name="org.qtproject.qt.android.bindings.QtApplication"
        android:label="Colo Course"
        android:icon="@mipmap/ic_launcher"
        android:hardwareAccelerated="true"
        android:allowBackup="true"
        android:fullBackupOnly="false"
        android:allowNativeHeapPointerTagging="false">

        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:label="Colo Course"
            android:launchMode="singleTop"
            android:screenOrientation="unspecified"
            android:exported="true"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc|density">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Remplacés par androiddeployqt : ne pas figer ces valeurs. -->
            <meta-data android:name="android.app.lib_name" android:value="-- %%INSERT_APP_LIB_NAME%% --"/>
            <meta-data android:name="android.app.arguments" android:value="-- %%INSERT_APP_ARGUMENTS%% --"/>
            <meta-data android:name="android.app.extract_android_style" android:value="minimal"/>
        </activity>
    </application>
</manifest>
